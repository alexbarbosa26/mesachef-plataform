APP_ENV=development
APP_VERSION=0.1.0
APP_PORT=3000
APP_HOST=127.0.0.1
APP_URL=http://localhost:5173

DATABASE_PROVIDER=postgres
DATABASE_URL=postgresql://mesachef:change-me-local-only@localhost:5432/mesachef
DATABASE_CONNECTION_TIMEOUT_MS=2000
DATABASE_POOL_MAX=4
DATABASE_MIGRATION_ALLOW_REMOTE=false

# Reservado para a SPEC 002. Não é consumido pela fundação.
AUTH_SECRET=

CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info
OPENAPI_ENABLED=true

# PostgreSQL local usado pelo Docker Compose. Substitua apenas no .env local.
POSTGRES_DB=mesachef
POSTGRES_USER=mesachef
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432
