APP_ENV=development
APP_VERSION=0.1.0
APP_PORT=3000
APP_HOST=127.0.0.1
APP_URL=http://localhost:5173

DATABASE_PROVIDER=sqlite
DATABASE_URL=:memory:
DATABASE_CONNECTION_TIMEOUT_MS=2000
DATABASE_POOL_MAX=1
DATABASE_MIGRATION_ALLOW_REMOTE=false

# Reservado para a SPEC 002. Não é consumido pela fundação.
AUTH_SECRET=

CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info
OPENAPI_ENABLED=true
