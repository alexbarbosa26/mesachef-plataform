{
  "name": "mesachef-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Fundação técnica do MesaChef Platform.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=11.9.0 <12"
  },
  "scripts": {
    "build:packages": "pnpm --filter \"./packages/*\" --workspace-concurrency=1 run build",
    "build": "pnpm -r --workspace-concurrency=1 run build",
    "check": "pnpm run lint && pnpm run check:boundaries && pnpm run check:compose && pnpm run typecheck && pnpm run test && pnpm run test:integration && pnpm run build",
    "check:boundaries": "node scripts/verify-boundaries.mjs",
    "check:compose": "node scripts/validate-compose.mjs",
    "db:config": "docker compose --env-file .env -f infra/docker/compose.yaml config",
    "db:down": "docker compose --env-file .env -f infra/docker/compose.yaml down",
    "db:logs": "docker compose --env-file .env -f infra/docker/compose.yaml logs -f postgres",
    "db:up": "docker compose --env-file .env -f infra/docker/compose.yaml up -d postgres",
    "dev": "pnpm run build:packages && concurrently --kill-others-on-fail --names api,web \"pnpm --filter @mesachef/api dev\" \"pnpm --filter @mesachef/web dev\"",
    "dev:api": "pnpm run build:packages && pnpm --filter @mesachef/api dev",
    "dev:web": "pnpm run build:packages && pnpm --filter @mesachef/web dev",
    "doctor": "node scripts/check-environment.mjs",
    "lint": "eslint . --max-warnings 0",
    "pretest": "pnpm run build:packages",
    "pretest:integration": "pnpm run build:packages",
    "pretypecheck": "pnpm run build:packages",
    "start:api": "pnpm --filter @mesachef/api start",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "pnpm -r --workspace-concurrency=1 run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
