{
  "name": "@mesachef/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./migrations": {
      "types": "./dist/migrations/index.d.ts",
      "import": "./dist/migrations/index.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "migrate:down": "node dist/migrations/cli.js down",
    "migrate:status": "node dist/migrations/cli.js status",
    "migrate:up": "node dist/migrations/cli.js up",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mesachef/domain": "workspace:*",
    "better-sqlite3": "12.11.1",
    "kysely": "0.29.4",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/pg": "8.20.0"
  }
}
