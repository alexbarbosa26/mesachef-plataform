{
  "name": "@mesachef/spike-postgres-rls",
  "version": "0.0.0",
  "private": true,
  "description": "Spike descartável para validar isolamento multiempresa com PostgreSQL 14 RLS, Kysely, transações e pool.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=11.9.0 <12"
  },
  "scripts": {
    "audit:secrets": "node scripts/audit-secrets.mjs",
    "build": "tsc --project tsconfig.json",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run test:postgres && pnpm run test:concurrency && pnpm run build && pnpm run audit:secrets",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:concurrency": "vitest run --config vitest.concurrency.config.ts",
    "test:postgres": "vitest run --config vitest.postgres.config.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "kysely": "0.29.4",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
