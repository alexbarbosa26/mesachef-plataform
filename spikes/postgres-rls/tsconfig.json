{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "target": "ES2024",
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "eslint.config.js",
    "scripts/**/*.mjs",
    "src/**/*.ts",
    "tests/**/*.ts",
    "vitest*.config.ts"
  ]
}
